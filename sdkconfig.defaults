# Defaults for SCADAESP32.
# Edit with: idf.py menuconfig -> SCADAESP32 Modbus RTU

CONFIG_SCADA_UART_TX_PIN=17
CONFIG_SCADA_UART_RX_PIN=16
CONFIG_SCADA_MODBUS_BAUDRATE=9600
CONFIG_SCADA_MODBUS_PARITY_NONE=y
CONFIG_SCADA_MODBUS_SLAVE_ID=1
CONFIG_SCADA_MODBUS_FUNCTION_CODE=0x03
CONFIG_SCADA_MODBUS_START_REGISTER=0x0000
CONFIG_SCADA_MODBUS_REGISTER_COUNT=2
CONFIG_SCADA_MODBUS_POLL_INTERVAL_MS=2000

# Common ESP32 DevKit boards often have 4 MB flash.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
